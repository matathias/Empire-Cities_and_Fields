<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- ═══════════════════════════════════════════════════════════
	     Second-order resources: produced only by city buildings
	     from raw material inputs. Cannot be produced by biomes.
	     ═══════════════════════════════════════════════════════════ -->

	<FactionColonies.ResourceTypeDef>
		<defName>RTD_ConsumerGoods</defName>
		<label>consumer goods</label>
		<description>Processed civilian goods — food products, household items, pharmaceuticals. Stockpiled to buffer settlements against negative events.</description>
		<iconPath>GUI/ProductionConsumerGoods</iconPath>
		<color>(0.85, 0.65, 0.25)</color>
		<uiPriority>1200</uiPriority>
		<isDefaultResource>false</isDefaultResource>
		<canTithe>false</canTithe>
		<productionAdditiveStat>RTD_ConsumerGoods_ProductionAdditive</productionAdditiveStat>
		<productionMultiplierStat>RTD_ConsumerGoods_ProductionMultiplier</productionMultiplierStat>
		<defaultBiomeAdditive>0</defaultBiomeAdditive>
		<defaultBiomeMultiplier>0</defaultBiomeMultiplier>
	</FactionColonies.ResourceTypeDef>

	<FactionColonies.ResourceTypeDef>
		<defName>RTD_Tools</defName>
		<label>tools &amp; machinery</label>
		<description>Industrial components and equipment. Boosts production at nearby rural settlements and can be tithed as components.</description>
		<iconPath>GUI/ProductionTools</iconPath>
		<color>(0.55, 0.55, 0.70)</color>
		<uiPriority>1300</uiPriority>
		<isDefaultResource>false</isDefaultResource>
		<productionAdditiveStat>RTD_Tools_ProductionAdditive</productionAdditiveStat>
		<productionMultiplierStat>RTD_Tools_ProductionMultiplier</productionMultiplierStat>
		<defaultBiomeAdditive>0</defaultBiomeAdditive>
		<defaultBiomeMultiplier>0</defaultBiomeMultiplier>
		<thingAllowList>
			<li>
				<thingDef>ComponentIndustrial</thingDef>
				<minTechLevel>Industrial</minTechLevel>
				<researchProjectDefs>
					<li>Fabrication</li>
				</researchProjectDefs>
			</li>
			<li>
				<thingDef>ComponentSpacer</thingDef>
				<researchProjectDefs>
					<li>AdvancedFabrication</li>
				</researchProjectDefs>
			</li>
		</thingAllowList>
		<titheMinCount>1</titheMinCount>
		<titheMaxCountBase>0</titheMaxCountBase>
		<titheMaxCountScaler>4</titheMaxCountScaler>
	</FactionColonies.ResourceTypeDef>

</Defs>
