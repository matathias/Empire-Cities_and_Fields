    <weight>10</weight>
    <minDaysSinceFounded>10</minDaysSinceFounded>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <applicableBiomes>
      <li>TemperateForest</li>
      <li>TemperateSwamp</li>
      <li>TropicalRainforest</li>
      <li>TropicalSwamp</li>
      <li>AridShrubland</li>
    </applicableBiomes>
    <requiredResource>RTD_Food</requiredResource>
    <incompatibleEvents>
      <li>ur_bountifulHarvest</li>
      <li>ur_cropBlight</li>
      <li>ur_drought</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>RTD_Food_ProductionMultiplier</stat>
        <value>1.1</value>
      </li>
      <li>
        <stat>happinessGainedBase</stat>
        <value>1</value>
      </li>
    </statModifiers>
    <randomThingValue>300</randomThingValue>
    <randomThingRewardDef>RERD_Food</randomThingRewardDef>
  </FactionColonies.FCEventDef>

</Defs>
