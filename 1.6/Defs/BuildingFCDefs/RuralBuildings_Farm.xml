<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- ═══════════════════════════════════════════════════════════
	     Farm buildings
	     ═══════════════════════════════════════════════════════════ -->

	<!-- ── Irrigation Ditch chain ── -->

	<FactionColonies.BuildingFCDef ParentName="BuildingFCDef_Farm">
		<defName>UR_IrrigationDitch</defName>
		<label>Irrigation Ditch</label>
		<desc>A network of channels that brings water to the fields, boosting food output.</desc>
		<cost>300</cost>
		<constructionDuration>60000</constructionDuration>
		<statModifiers>
			<li><stat>RTD_Food_ProductionAdditive</stat><value>0.5</value></li>
		</statModifiers>
		<upkeep>0</upkeep>
		<iconPath>Buildings/UR_IrrigationDitch</iconPath>
		<upgrades>
			<li>UR_AqueductSystem</li>
			<li>UR_TerracedFields</li>
		</upgrades>
	</FactionColonies.BuildingFCDef>

	<FactionColonies.BuildingFCDef ParentName="BuildingFCDef_Farm">
		<defName>UR_AqueductSystem</defName>
		<label>Aqueduct System</label>
		<desc>A stone-lined aqueduct that delivers a steady flow of water across the farmland, greatly increasing food yields.</desc>
		<cost>1500</cost>
		<constructionDuration>150000</constructionDuration>
		<statModifiers>
			<li><stat>RTD_Food_ProductionAdditive</stat><value>1.25</value></li>
		</statModifiers>
		<upkeep>75</upkeep>
		<baseBuilding>false</baseBuilding>
		<iconPath>Buildings/UR_AqueductSystem</iconPath>
		<upgrades>
			<li>UR_ReservoirNetwork</li>
			<li>UR_HydroponicsWing</li>
		</upgrades>
	</FactionColonies.BuildingFCDef>

	<FactionColonies.BuildingFCDef ParentName="BuildingFCDef_Farm">
		<defName>UR_ReservoirNetwork</defName>
		<label>Reservoir Network</label>
		<desc>A system of interconnected reservoirs that stores and distributes water across all growing zones, maximizing food production. Requires power to operate pumping stations.</desc>
		<cost>3500</cost>
		<constructionDuration>300000</constructionDuration>
		<techLevel>Industrial</techLevel>
		<statModifiers>
			<li><stat>RTD_Food_ProductionAdditive</stat><value>2.5</value></li>
		</statModifiers>
		<upkeep>150</upkeep>
		<baseBuilding>false</baseBuilding>
		<iconPath>Buildings/UR_ReservoirNetwork</iconPath>
		<modExtensions>
			<li Class="FactionColonies.SupplyChain.BuildingNeedExtension">
				<inputs>
					<li><resource>RTD_Power</resource><amount>0.5</amount></li>
				</inputs>
				<penalties>
					<li><stat>happinessLostBase</stat><penaltyPerUnit>2.0</penaltyPerUnit><label>irrigation offline</label></li>
				</penalties>
			</li>
		</modExtensions>
	</FactionColonies.BuildingFCDef>

	<FactionColonies.BuildingFCDef ParentName="BuildingFCDef_Farm">
		<defName>UR_HydroponicsWing</defName>
		<label>Aeroponic Chamber</label>
		<desc>A sealed chamber using aeroponic misting systems to grow crops without soil. Produces excellent food yields with an efficiency multiplier, but requires significant power.</desc>
		<cost>4500</cost>
		<constructionDuration>360000</constructionDuration>
		<techLevel>Industrial</techLevel>
		<statModifiers>
			<li><stat>RTD_Food_ProductionAdditive</stat><value>1.75</value></li>
			<li><stat>RTD_Food_ProductionMultiplier</stat><value>1.25</value></li>
		</statModifiers>
		<upkeep>200</upkeep>
		<baseBuilding>false</baseBuilding>
		<iconPath>Buildings/UR_HydroponicsWing</iconPath>
		<modExtensions>
			<li Class="FactionColonies.SupplyChain.BuildingNeedExtension">
				<inputs>
					<li><resource>RTD_Power</resource><amount>1.0</amount></li>
				</inputs>
				<penalties>
					<li><stat>happinessLostBase</stat><penaltyPerUnit>2.0</penaltyPerUnit><label>greenhouse offline</label></li>
				</penalties>
			</li>
		</modExtensions>
	</FactionColonies.BuildingFCDef>

	<FactionColonies.BuildingFCDef ParentName="BuildingFCDef_Farm">
		<defName>UR_TerracedFields</defName>
		<label>Terraced Fields</label>
		<desc>Carefully sculpted terraces that make use of hillside land, boosting food output and providing a pleasant landscape for workers.</desc>
		<cost>1000</cost>
		<constructionDuration>120000</constructionDuration>
		<statModifiers>
			<li><stat>RTD_Food_ProductionAdditive</stat><value>1.25</value></li>
			<li><stat>happinessGainedBase</stat><value>0.5</value></li>
		</statModifiers>
		<upkeep>50</upkeep>
		<baseBuilding>false</baseBuilding>
		<iconPath>Buildings/UR_TerracedFields</iconPath>
	</FactionColonies.BuildingFCDef>

	<!-- ── Fertile Fields chain ── -->

	<FactionColonies.BuildingFCDef ParentName="BuildingFCDef_Farm">
		<defName>UR_FertileFields</defName>
		<label>Fertile Fields</label>
		<desc>Carefully enriched farmland that amplifies all food production.</desc>
		<cost>500</cost>
		<constructionDuration>90000</constructionDuration>
		<statModifiers>
			<li><stat>RTD_Food_ProductionMultiplier</stat><value>1.1</value></li>
		</statModifiers>
		<upkeep>50</upkeep>
		<iconPath>Buildings/UR_FertileFields</iconPath>
		<upgrades>
			<li>UR_EnrichedSoil</li>
			<li>UR_CropRotation</li>
		</upgrades>
	</FactionColonies.BuildingFCDef>

	<FactionColonies.BuildingFCDef ParentName="BuildingFCDef_Farm">
		<defName>UR_EnrichedSoil</defName>
		<label>Enriched Soil</label>
		<desc>Soil enriched with carefully balanced nutrients that significantly boosts crop yields.</desc>
		<cost>1500</cost>
		<constructionDuration>150000</constructionDuration>
		<statModifiers>
			<li><stat>RTD_Food_ProductionMultiplier</stat><value>1.25</value></li>
		</statModifiers>
		<upkeep>100</upkeep>
		<baseBuilding>false</baseBuilding>
		<iconPath>Buildings/UR_EnrichedSoil</iconPath>
		<upgrades>
			<li>UR_GMOCrops</li>
		</upgrades>
	</FactionColonies.BuildingFCDef>

	<FactionColonies.BuildingFCDef ParentName="BuildingFCDef_Farm">
		<defName>UR_GMOCrops</defName>
		<label>GMO Crops</label>
		<desc>Genetically modified crop strains engineered for maximum yield. Requires a steady stream of research data to maintain the program.</desc>
		<cost>4000</cost>
		<constructionDuration>360000</constructionDuration>
		<techLevel>Industrial</techLevel>
		<statModifiers>
			<li><stat>RTD_Food_ProductionMultiplier</stat><value>1.5</value></li>
		</statModifiers>
		<upkeep>200</upkeep>
		<baseBuilding>false</baseBuilding>
		<iconPath>Buildings/UR_GMOCrops</iconPath>
		<modExtensions>
			<li Class="FactionColonies.SupplyChain.BuildingNeedExtension">
				<inputs>
					<li><resource>RTD_Research</resource><amount>0.2</amount></li>
				</inputs>
				<penalties>
					<li><stat>happinessLostBase</stat><penaltyPerUnit>1.5</penaltyPerUnit><label>research supply disrupted</label></li>
				</penalties>
			</li>
		</modExtensions>
	</FactionColonies.BuildingFCDef>

	<FactionColonies.BuildingFCDef ParentName="BuildingFCDef_Farm">
		<defName>UR_CropRotation</defName>
		<label>Crop Rotation</label>
		<desc>A systematic rotation of crops that improves soil health, providing both a multiplier to existing yields and additional food output.</desc>
		<cost>1200</cost>
		<constructionDuration>120000</constructionDuration>
		<statModifiers>
			<li><stat>RTD_Food_ProductionMultiplier</stat><value>1.15</value></li>
			<li><stat>RTD_Food_ProductionAdditive</stat><value>0.5</value></li>
		</statModifiers>
		<upkeep>75</upkeep>
		<baseBuilding>false</baseBuilding>
		<iconPath>Buildings/UR_CropRotation</iconPath>
		<upgrades>
			<li>UR_AgriScience</li>
		</upgrades>
	</FactionColonies.BuildingFCDef>

	<FactionColonies.BuildingFCDef ParentName="BuildingFCDef_Farm">
		<defName>UR_AgriScience</defName>
		<label>Agricultural Science Center</label>
		<desc>A research-driven agricultural facility that combines crop science with practical farming for outstanding yields. Requires ongoing research input.</desc>
		<cost>3500</cost>
		<constructionDuration>300000</constructionDuration>
		<techLevel>Industrial</techLevel>
		<statModifiers>
			<li><stat>RTD_Food_ProductionMultiplier</stat><value>1.3</value></li>
			<li><stat>RTD_Food_ProductionAdditive</stat><value>1.0</value></li>
		</statModifiers>
		<upkeep>175</upkeep>
		<baseBuilding>false</baseBuilding>
		<iconPath>Buildings/UR_AgriScience</iconPath>
		<modExtensions>
			<li Class="FactionColonies.SupplyChain.BuildingNeedExtension">
				<inputs>
					<li><resource>RTD_Research</resource><amount>0.1</amount></li>
				</inputs>
				<penalties>
					<li><stat>happinessLostBase</stat><penaltyPerUnit>1.5</penaltyPerUnit><label>research supply disrupted</label></li>
				</penalties>
			</li>
		</modExtensions>
	</FactionColonies.BuildingFCDef>


</Defs>
