<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!-- ═══════════════════════════════════════════════════════════
	     Lumber Camp buildings
	     ═══════════════════════════════════════════════════════════ -->

	<!-- ── Sawmill chain ── -->

	<FactionColonies.BuildingFCDef ParentName="BuildingFCDef_LumberCamp">
		<defName>UR_Sawmill</defName>
		<label>Sawmill</label>
		<desc>A mechanical sawmill that speeds up timber processing.</desc>
		<cost>350</cost>
		<constructionDuration>60000</constructionDuration>
		<statModifiers>
			<li><stat>RTD_Logging_ProductionAdditive</stat><value>0.5</value></li>
		</statModifiers>
		<upkeep>0</upkeep>
		<iconPath>Buildings/UR_Sawmill</iconPath>
		<upgrades>
			<li>UR_SteamSawmill</li>
			<li>UR_ForestryOffice</li>
		</upgrades>
	</FactionColonies.BuildingFCDef>

	<FactionColonies.BuildingFCDef ParentName="BuildingFCDef_LumberCamp">
		<defName>UR_SteamSawmill</defName>
		<label>Steam Sawmill</label>
		<desc>A power-driven sawmill that processes timber far faster than manual methods. Requires a modest power supply.</desc>
		<cost>850</cost>
		<constructionDuration>90000</constructionDuration>
		<techLevel>Industrial</techLevel>
		<statModifiers>
			<li><stat>RTD_Logging_ProductionAdditive</stat><value>1.5</value></li>
		</statModifiers>
		<upkeep>100</upkeep>
		<baseBuilding>false</baseBuilding>
		<iconPath>Buildings/UR_SteamSawmill</iconPath>
		<upgrades>
			<li>UR_IndustrialMill</li>
		</upgrades>
		<modExtensions>
			<li Class="FactionColonies.SupplyChain.BuildingNeedExtension">
				<inputs>
					<li><resource>RTD_Power</resource><amount>0.2</amount></li>
				</inputs>
				<penalties>
					<li><stat>happinessLostBase</stat><penaltyPerUnit>1.5</penaltyPerUnit><label>power outage</label></li>
				</penalties>
			</li>
		</modExtensions>
	</FactionColonies.BuildingFCDef>

	<FactionColonies.BuildingFCDef ParentName="BuildingFCDef_LumberCamp">
		<defName>UR_IndustrialMill</defName>
		<label>Industrial Mill</label>
		<desc>A fully mechanized lumber mill with conveyor systems and automated cutting. Requires significant power to operate.</desc>
		<cost>2000</cost>
		<constructionDuration>120000</constructionDuration>
		<techLevel>Industrial</techLevel>
		<statModifiers>
			<li><stat>RTD_Logging_ProductionAdditive</stat><value>2.5</value></li>
		</statModifiers>
		<upkeep>200</upkeep>
		<baseBuilding>false</baseBuilding>
		<iconPath>Buildings/UR_IndustrialMill</iconPath>
		<modExtensions>
			<li Class="FactionColonies.SupplyChain.BuildingNeedExtension">
				<inputs>
					<li><resource>RTD_Power</resource><amount>0.5</amount></li>
				</inputs>
				<penalties>
					<li><stat>happinessLostBase</stat><penaltyPerUnit>2.0</penaltyPerUnit><label>power outage</label></li>
				</penalties>
			</li>
		</modExtensions>
	</FactionColonies.BuildingFCDef>

	<FactionColonies.BuildingFCDef ParentName="BuildingFCDef_LumberCamp">
		<defName>UR_ForestryOffice</defName>
		<label>Forestry Office</label>
		<desc>A well-managed office that coordinates logging operations sustainably, improving output and worker satisfaction.</desc>
		<cost>600</cost>
		<constructionDuration>75000</constructionDuration>
		<statModifiers>
			<li><stat>RTD_Logging_ProductionAdditive</stat><value>1.0</value></li>
			<li><stat>happinessGainedBase</stat><value>0.5</value></li>
		</statModifiers>
		<upkeep>50</upkeep>
		<baseBuilding>false</baseBuilding>
		<iconPath>Buildings/UR_ForestryOffice</iconPath>
		<upgrades>
			<li>UR_NatureReserve</li>
		</upgrades>
	</FactionColonies.BuildingFCDef>

	<FactionColonies.BuildingFCDef ParentName="BuildingFCDef_LumberCamp">
		<defName>UR_NatureReserve</defName>
		<label>Nature Reserve</label>
		<desc>A managed woodland reserve that balances sustainable logging with conservation, greatly improving worker morale.</desc>
		<cost>1500</cost>
		<constructionDuration>120000</constructionDuration>
		<techLevel>Industrial</techLevel>
		<statModifiers>
			<li><stat>RTD_Logging_ProductionAdditive</stat><value>1.75</value></li>
			<li><stat>happinessGainedBase</stat><value>1.0</value></li>
		</statModifiers>
		<upkeep>125</upkeep>
		<baseBuilding>false</baseBuilding>
		<iconPath>Buildings/UR_NatureReserve</iconPath>
	</FactionColonies.BuildingFCDef>

	<!-- ── Timber Yard chain ── -->

	<FactionColonies.BuildingFCDef ParentName="BuildingFCDef_LumberCamp">
		<defName>UR_TimberYard</defName>
		<label>Timber Yard</label>
		<desc>An organized yard for curing and storing timber, improving overall logging efficiency.</desc>
		<cost>850</cost>
		<constructionDuration>90000</constructionDuration>
		<statModifiers>
			<li><stat>RTD_Logging_ProductionMultiplier</stat><value>1.1</value></li>
		</statModifiers>
		<upkeep>50</upkeep>
		<iconPath>Buildings/UR_TimberYard</iconPath>
		<upgrades>
			<li>UR_CuringFacility</li>
			<li>UR_TimberExchange</li>
		</upgrades>
	</FactionColonies.BuildingFCDef>

	<FactionColonies.BuildingFCDef ParentName="BuildingFCDef_LumberCamp">
		<defName>UR_CuringFacility</defName>
		<label>Curing Facility</label>
		<desc>A specialized facility for drying and treating lumber, producing higher-quality timber that fetches better prices.</desc>
		<cost>1000</cost>
		<constructionDuration>90000</constructionDuration>
		<statModifiers>
			<li><stat>RTD_Logging_ProductionMultiplier</stat><value>1.25</value></li>
		</statModifiers>
		<upkeep>100</upkeep>
		<baseBuilding>false</baseBuilding>
		<iconPath>Buildings/UR_CuringFacility</iconPath>
		<upgrades>
			<li>UR_LumberProcessing</li>
		</upgrades>
	</FactionColonies.BuildingFCDef>

	<FactionColonies.BuildingFCDef ParentName="BuildingFCDef_LumberCamp">
		<defName>UR_LumberProcessing</defName>
		<label>Lumber Processing Plant</label>
		<desc>An industrial-scale lumber processing facility with power-driven planers and kilns. Requires a steady power supply.</desc>
		<cost>2000</cost>
		<constructionDuration>120000</constructionDuration>
		<techLevel>Industrial</techLevel>
		<statModifiers>
			<li><stat>RTD_Logging_ProductionMultiplier</stat><value>1.5</value></li>
		</statModifiers>
		<upkeep>200</upkeep>
		<baseBuilding>false</baseBuilding>
		<iconPath>Buildings/UR_LumberProcessing</iconPath>
		<modExtensions>
			<li Class="FactionColonies.SupplyChain.BuildingNeedExtension">
				<inputs>
					<li><resource>RTD_Power</resource><amount>0.3</amount></li>
				</inputs>
				<penalties>
					<li><stat>happinessLostBase</stat><penaltyPerUnit>2.0</penaltyPerUnit><label>power outage</label></li>
				</penalties>
			</li>
		</modExtensions>
	</FactionColonies.BuildingFCDef>

	<FactionColonies.BuildingFCDef ParentName="BuildingFCDef_LumberCamp">
		<defName>UR_TimberExchange</defName>
		<label>Timber Exchange</label>
		<desc>A trading post that connects the lumber camp to regional markets, improving logging efficiency and tax revenue.</desc>
		<cost>800</cost>
		<constructionDuration>90000</constructionDuration>
		<statModifiers>
			<li><stat>RTD_Logging_ProductionMultiplier</stat><value>1.2</value></li>
			<li><stat>taxBasePercentage</stat><value>10</value></li>
		</statModifiers>
		<upkeep>75</upkeep>
		<baseBuilding>false</baseBuilding>
		<iconPath>Buildings/UR_TimberExchange</iconPath>
	</FactionColonies.BuildingFCDef>


</Defs>
