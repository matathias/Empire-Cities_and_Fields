<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- ═══════════════════════════════════════════════════════════
	     Production stats for second-order resources.
	     Two per resource: additive base and multiplier.
	     ═══════════════════════════════════════════════════════════ -->

	<FactionColonies.FCStatDef>
		<defName>RTD_ConsumerGoods_ProductionAdditive</defName>
		<aggregation>Additive</aggregation>
		<linkedResource>RTD_ConsumerGoods</linkedResource>
	</FactionColonies.FCStatDef>
	<FactionColonies.FCStatDef>
		<defName>RTD_ConsumerGoods_ProductionMultiplier</defName>
		<aggregation>Multiplicative</aggregation>
		<linkedResource>RTD_ConsumerGoods</linkedResource>
	</FactionColonies.FCStatDef>

	<FactionColonies.FCStatDef>
		<defName>RTD_Tools_ProductionAdditive</defName>
		<aggregation>Additive</aggregation>
		<linkedResource>RTD_Tools</linkedResource>
	</FactionColonies.FCStatDef>
	<FactionColonies.FCStatDef>
		<defName>RTD_Tools_ProductionMultiplier</defName>
		<aggregation>Multiplicative</aggregation>
		<linkedResource>RTD_Tools</linkedResource>
	</FactionColonies.FCStatDef>

</Defs>
