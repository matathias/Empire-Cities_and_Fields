<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- ═══ City ═══ -->
	<FactionColonies.WorldSettlementDef ParentName="WorldSettlementDefBase">
		<defName>WorldSettlementDef_City</defName>
		<label>city</label>
		<description>A large urban center with no biome resource production. Depends on supply routes from rural settlements to satisfy its needs, but can produce mid-tier resources via specialized buildings.</description>
		<baseSettlementType>WorldSettlementDef_Surface</baseSettlementType>
		<baseUnlockedBuildings>0</baseUnlockedBuildings>
		<perLevelUnlockedBuildings>1</perLevelUnlockedBuildings>
		<maxBuildingCount>16</maxBuildingCount>
		<defaultResources>true</defaultResources>
		<resources>
			<li>
				<resourceDef>RTD_Chemfuel</resourceDef>
			</li>
		</resources>
		<biomeResourceOverride>UrbanRural_EmptyBiome</biomeResourceOverride>
		<planetLayers>
			<li>Surface</li>
		</planetLayers>
		<comps>
			<li Class="WorldObjectCompProperties_TradeRequest" />
			<li Class="FactionColonies.WorldObjectCompProperties_SettlementOpenWindow" />
			<li Class="FactionColonies.WorldObjectCompProperties_SettlementMilitary" />
			<li Class="FactionColonies.WorldObjectCompProperties_SettlementBuildings" />
		</comps>
		<modExtensions>
			<li Class="FactionColonies.UrbanRural.SettlementTypeExtension_Urban" />
		</modExtensions>
	</FactionColonies.WorldSettlementDef>

</Defs>
