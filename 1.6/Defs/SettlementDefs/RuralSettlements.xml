		<defName>WorldSettlementDef_Farm</defName>
		<label>farming hamlet</label>
		<description>A small rural settlement specializing in food production. Benefits from fertile biomes.</description>
		<available>true</available>
		<accentColor>(0.30, 0.50, 0.23)</accentColor>
		<baseSettlementType>WorldSettlementDef_Rural</baseSettlementType>
		<defaultResources>false</defaultResources>
		<resources>
			<li><resourceDef>RTD_Food</resourceDef><additive>0.5</additive><multiplier>1.5</multiplier></li>
			<li><resourceDef>RTD_Mining</resourceDef><multiplier>0.5</multiplier></li>
			<li><resourceDef>RTD_Logging</resourceDef><multiplier>0.5</multiplier></li>
