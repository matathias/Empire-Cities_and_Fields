<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- ═══ Rural Base (hidden — used only for building allow/block list inheritance) ═══ -->
	<FactionColonies.WorldSettlementDef ParentName="WorldSettlementDefBase">
		<defName>WorldSettlementDef_Rural</defName>
		<label>rural settlement</label>
		<description>Base rural settlement type. Not directly buildable.</description>
		<available>false</available>
		<baseSettlementType>WorldSettlementDef_Surface</baseSettlementType>
		<planetLayers>
			<li>Surface</li>
		</planetLayers>
		<modExtensions>
			<li Class="FactionColonies.SettlementTypeExtension" />
		</modExtensions>
	</FactionColonies.WorldSettlementDef>

	<!-- ═══ Farming Hamlet ═══ -->
	<FactionColonies.WorldSettlementDef ParentName="WorldSettlementDefBase">
		<defName>WorldSettlementDef_Farm</defName>
		<label>farming hamlet</label>
		<description>A small rural settlement specializing in food production. Benefits from fertile biomes.</description>
		<baseSettlementType>WorldSettlementDef_Rural</baseSettlementType>
		<defaultResources>false</defaultResources>
		<resources>
			<li>
				<resourceDef>RTD_Food</resourceDef>
				<additive>2</additive>
				<multiplier>1.5</multiplier>
			</li>
		</resources>
		<planetLayers>
			<li>Surface</li>
		</planetLayers>
		<comps>
			<li Class="WorldObjectCompProperties_TradeRequest" />
			<li Class="FactionColonies.WorldObjectCompProperties_SettlementOpenWindow" />
			<li Class="FactionColonies.WorldObjectCompProperties_SettlementMilitary" />
			<li Class="FactionColonies.WorldObjectCompProperties_SettlementBuildings" />
			<li Class="FactionColonies.UrbanRural.WorldObjectCompProperties_RuralSettlement" />
		</comps>
		<modExtensions>
			<li Class="FactionColonies.UrbanRural.SettlementTypeExtension_Farm" />
		</modExtensions>
	</FactionColonies.WorldSettlementDef>

