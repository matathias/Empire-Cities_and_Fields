<Defs>

	<!-- ═══ Rural Base (hidden — used only for building allow/block list inheritance) ═══ -->
	<FactionColonies.WorldSettlementDef Name="WorldSettlementDef_Rural" ParentName="WorldSettlementDef_Surface">
		<defName>WorldSettlementDef_Rural</defName>
		<label>rural settlement</label>
		<description>Base rural settlement type. Not directly buildable.</description>
		<available>false</available>
		<baseSettlementType>WorldSettlementDef_Surface</baseSettlementType>
		<maxBuildingCount>8</maxBuildingCount>
		<comps>
			<li Class="FactionColonies.UrbanRural.WorldObjectCompProperties_ToolsBenefit" />
		</comps>
		<modExtensions>
			<li Class="FactionColonies.UrbanRural.SettlementTypeExtension_Rural" />
		</modExtensions>
	</FactionColonies.WorldSettlementDef>

